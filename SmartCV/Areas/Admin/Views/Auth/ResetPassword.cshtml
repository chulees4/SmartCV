@model SmartCV.ViewModels.Auth.ResetPasswordViewModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu Admin";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>SmartCV Admin — Đặt lại mật khẩu</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body { background: #f4f6f9; display: flex; align-items: center; min-height: 100vh; }
        .card { max-width: 420px; width: 100%; margin: auto; }
    </style>
</head>
<body>
    <div class="container">
        <div class="card shadow-sm p-4">
            <h5 class="fw-bold mb-4">Đặt lại mật khẩu</h5>

            @if (TempData["Error"] != null) { <div class="alert alert-danger">@TempData["Error"]</div> }

            <form method="post">
                @Html.AntiForgeryToken()
                <input asp-for="Token" type="hidden" />
                <input asp-for="Email" type="hidden" />
                <input asp-for="UserType" type="hidden" />
                <div class="mb-3">
                    <label class="form-label">Mật khẩu mới</label>
                    <input asp-for="NewPassword" class="form-control" placeholder="Tối thiểu 6 ký tự" />
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label">Xác nhận mật khẩu</label>
                    <input asp-for="ConfirmPassword" class="form-control" placeholder="Nhập lại mật khẩu" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>
                <button class="btn btn-primary w-100">Đặt lại mật khẩu</button>
            </form>
        </div>
    </div>
</body>
</html>

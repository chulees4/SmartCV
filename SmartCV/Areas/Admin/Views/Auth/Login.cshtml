@model SmartCV.ViewModels.Auth.LoginViewModel
@{
    ViewData["Title"] = "Admin Login";
    Layout = null; // Trang login Admin không dùng layout chung
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>SmartCV Admin — Đăng nhập</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body { background: #f4f6f9; display: flex; align-items: center; min-height: 100vh; }
        .login-card { max-width: 420px; width: 100%; margin: auto; }
    </style>
</head>
<body>
    <div class="container">
        <div class="login-card card shadow-sm p-4">
            <div class="text-center mb-4">
                <h4 class="fw-bold">SmartCV Admin</h4>
                <p class="text-muted small">Đăng nhập vào trang quản trị</p>
            </div>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible">@TempData["Success"]</div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger">@TempData["Error"]</div>
            }

            <form asp-action="Login" asp-controller="Auth" asp-area="Admin" method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label fw-semibold">Email</label>
                    <input asp-for="Email" class="form-control" placeholder="admin@smartcv.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-semibold">Mật khẩu</label>
                    <input asp-for="Password" class="form-control" placeholder="••••••••" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="form-check">
                        <input asp-for="RememberMe" class="form-check-input" />
                        <label class="form-check-label small" asp-for="RememberMe">Ghi nhớ</label>
                    </div>
                    <a asp-action="ForgotPassword" asp-controller="Auth" asp-area="Admin" class="small">Quên mật khẩu?</a>
                </div>
                <button type="submit" class="btn btn-primary w-100">Đăng nhập</button>
            </form>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/dist/jquery.validate.unobtrusive.min.js"></script>
</body>
</html>

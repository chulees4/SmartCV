@model SmartCV.ViewModels.Auth.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Quên mật khẩu Admin";
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>SmartCV Admin — Quên mật khẩu</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body { background: #f4f6f9; display: flex; align-items: center; min-height: 100vh; }
        .card { max-width: 420px; width: 100%; margin: auto; }
    </style>
</head>
<body>
    <div class="container">
        <div class="card shadow-sm p-4">
            <h5 class="fw-bold mb-1">Đặt lại mật khẩu Admin</h5>
            <p class="text-muted small mb-4">Nhập email. Chúng tôi sẽ gửi link đặt lại mật khẩu.</p>

            @if (TempData["Success"] != null) { <div class="alert alert-success">@TempData["Success"]</div> }
            @if (TempData["Error"] != null)   { <div class="alert alert-danger">@TempData["Error"]</div> }

            <form method="post">
                @Html.AntiForgeryToken()
                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" placeholder="admin@smartcv.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>
                <button class="btn btn-primary w-100">Gửi email</button>
            </form>
            <p class="text-center mt-3 small">
                <a asp-action="Login" asp-controller="Auth" asp-area="Admin">← Quay lại đăng nhập</a>
            </p>
        </div>
    </div>
</body>
</html>

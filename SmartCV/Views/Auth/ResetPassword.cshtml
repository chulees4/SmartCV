@model SmartCV.ViewModels.Auth.ResetPasswordViewModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
}

<section class="login-area pt-120 pb-120">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-xl-5 col-lg-6 col-md-8">
                <div class="login-wrapper">
                    <h3 class="login-title text-center mb-30">Đặt lại mật khẩu</h3>

                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger">@TempData["Error"]</div>
                    }

                    <form method="post">
                        @Html.AntiForgeryToken()
                        <input asp-for="Token" type="hidden" />
                        <input asp-for="Email" type="hidden" />
                        <input asp-for="UserType" type="hidden" />
                        <div class="mb-3">
                            <label class="form-label">Mật khẩu mới</label>
                            <input asp-for="NewPassword" class="form-control" placeholder="Tối thiểu 6 ký tự" />
                            <span asp-validation-for="NewPassword" class="text-danger small"></span>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Xác nhận mật khẩu</label>
                            <input asp-for="ConfirmPassword" class="form-control" placeholder="Nhập lại mật khẩu mới" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Đặt lại mật khẩu</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }

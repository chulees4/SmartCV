@model SmartCV.ViewModels.Auth.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Quên mật khẩu";
    var userType = ViewBag.UserType?.ToString() ?? "candidate";
    var label = userType == "company" ? "Email công ty" : "Email tài khoản";
}

<section class="login-area pt-120 pb-120">
    <div class="container">
        <div class="row justify-content-center">
            <div class="col-xl-5 col-lg-6 col-md-8">
                <div class="login-wrapper text-center">
                    <h3 class="login-title mb-10">Quên mật khẩu</h3>
                    <p class="text-muted mb-30">Nhập email đã đăng ký để nhận link đặt lại mật khẩu.</p>

                    @if (TempData["Success"] != null)
                    {
                        <div class="alert alert-success">@TempData["Success"]</div>
                    }
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger">@TempData["Error"]</div>
                    }

                    <form method="post">
                        @Html.AntiForgeryToken()
                        <div class="mb-3 text-start">
                            <label class="form-label">@label</label>
                            <input asp-for="Email" class="form-control" placeholder="email@example.com" />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Gửi email đặt lại mật khẩu</button>
                    </form>

                    <p class="mt-3"><a href="/login">← Quay lại đăng nhập</a></p>
                </div>
            </div>
        </div>
    </div>
</section>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }
